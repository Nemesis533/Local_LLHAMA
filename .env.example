# Home Assistant Configuration
# Your Home Assistant base URL (e.g., http://homeassistant.local:8123)
HA_BASE_URL=http://homeassistant.local:8123

# Your Home Assistant Long-Lived Access Token
# Generate one from: Home Assistant -> Profile -> Long-Lived Access Tokens
HA_TOKEN=your_home_assistant_token_here

# Ollama Configuration (if using Ollama)
# The IP address and port of your Ollama server (e.g., 192.168.88.239:11434)
OLLAMA_IP=192.168.88.239:11434

# Web Server Security
# Comma-separated list of allowed IP prefixes for web UI access
# Example: 192.168.1.,127.0.0.1,10.0.0.
ALLOWED_IP_PREFIXES=192.168.88.,127.0.0.1
